{
  "name": "lightspeed-talent-assessment",
  "version": "0.1.0",
  "description": "SP-002 starter scaffold for Type 2 applications \u2014 Template App",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build",
    "start": "npm run build && NODE_ENV=production tsx server.ts",
    "preview": "vite preview --host 0.0.0.0",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx server/src/seed.ts",
    "db:studio": "drizzle-kit studio",
    "test:e2e": "npx playwright test",
    "test:rest": "npx playwright test --grep @rest --reporter=list",
    "test:dom": "npx playwright test --grep @dom",
    "typecheck": "tsc --noEmit",
    "db:seed:hiring": "tsx server/src/seedHiring.ts",
    "db:seed:values": "tsx server/src/seedValues.ts",
    "db:seed:epp": "tsx server/src/seedEpp.ts",
    "db:seed:employees": "tsx server/src/seedEmployees.ts",
    "db:seed:reviews": "tsx server/src/seedReviews.ts",
    "db:seed:realjobs": "tsx server/src/seedRealJobs.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.64",
    "@fontsource/inter": "^5.2.8",
    "@replit/object-storage": "^1.0.0",
    "@tanstack/react-query": "^4.43.0",
    "@trpc/client": "^10.45.4",
    "@trpc/react-query": "^10.45.4",
    "@trpc/server": "^10.45.4",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "ai": "^6.0.138",
    "autoprefixer": "^10.4.20",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "concurrently": "^9.1.0",
    "connect-pg-simple": "^10.0.0",
    "cors": "^2.8.5",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.1",
    "express": "^4.21.0",
    "express-session": "^1.19.0",
    "html2canvas": "^1.4.1",
    "lucide-react": "^0.468.0",
    "pg": "^8.20.0",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.0",
    "recharts": "^2.15.0",
    "superjson": "^2.2.6",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^6.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.42.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/express-session": "^1.19.0"
  }
