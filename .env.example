############################################
# Template App — environment template
#
# Copy to `.env` for local dev, or populate Replit Secrets for a
# deployed instance. NEVER commit populated values.
############################################

# --- Runtime -------------------------------------------------------------

# `development` | `production`.
NODE_ENV=development

# Port the Express server binds to. Single process serves both the API
# and the SPA (Vite middleware in dev, built dist/ in production).
PORT=5000

# --- Database (required) -------------------------------------------------

DATABASE_URL=postgresql://user:password@localhost:5432/template_app

# --- Session / Auth (required) -------------------------------------------
#
# Auth is email/password with Postgres-backed sessions (express-session +
# connect-pg-simple) plus a stateless HMAC bearer token for cross-site
# iframe contexts (e.g. the Replit preview). SESSION_SECRET signs BOTH the
# session cookie and the bearer token — rotating it invalidates all active
# sessions and tokens.
#
# Generate: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-32-char-random-string

# Seed admin bootstrap. The first account registered with this email is
# auto-promoted to `sysadmin` (idempotent — also promotes an existing
# still-default `user` with this email). Case-insensitive. Safe to leave
# set; manage additional admins through the Admin UI afterward.
SEED_SUPER_ADMIN_EMAIL=

# --- AI (optional) -------------------------------------------------------
#
# When unset, the chat falls back to canned/demo responses.
ANTHROPIC_API_KEY=sk-ant-...

# --- Agent feedback harness (optional) -----------------------------------
#
# Per-app key for the cross-app debug-agent HTTP surface (/api/feedback).
# Leave unset to disable that surface.
AGENT_API_KEY=
