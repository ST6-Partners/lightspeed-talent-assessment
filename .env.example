############################################
# AI Talent Assessment (lightspeed-talent-assessment)
# Environment configuration template.
#
# Copy to `.env` for local dev, or set these as Railway service
# variables (or Replit Secrets) for a deployed instance.
# NEVER commit populated values.
#
# HOW TO READ THIS FILE
# Each setting notes what happens if you leave it BLANK. Many features
# are OPTIONAL and fall back to a safe "sandbox" mode when unconfigured
# (they log instead of doing the real thing) rather than erroring. That
# means a blank key = the feature is silently OFF, not broken. Fill in a
# group's keys to switch that feature on.
############################################


# ======================================================================
# RUNTIME
# ======================================================================

# `development` | `production` | `test`
NODE_ENV=development

# Port the Express server binds to. One process serves both the API and
# the web app. Railway sets this automatically; default is 5000.
PORT=5000

# Public base URL of the deployed app, used to build links inside emails
# (offer/approval/work-sample links). If blank, the app derives it from
# RAILWAY_PUBLIC_DOMAIN / Replit domain, falling back to localhost.
# Set this in production so emailed links point at the real site.
APP_BASE_URL=

# Set automatically by the hosting platform — do NOT set by hand:
#   RAILWAY_PUBLIC_DOMAIN  (Railway)
#   REPLIT_DOMAINS / REPLIT_DEV_DOMAIN  (Replit)


# ======================================================================
# DATABASE  (required)
# ======================================================================

# Postgres connection string. Required in every environment. Blank/default
# points at a local template DB and the app will not work against real data.
DATABASE_URL=postgresql://user:password@localhost:5432/talent_assessment


# ======================================================================
# SESSION / AUTH  (required)
# ======================================================================

# Signs the session cookie AND the bearer token. Rotating it logs everyone
# out. Generate with: openssl rand -hex 32
# If blank, a known dev-only default is used — NEVER acceptable in production.
SESSION_SECRET=change-me-to-a-32-char-random-string

# The first account registered with this email is auto-promoted to sysadmin.
# Case-insensitive. Blank = no auto-admin; you must promote an admin manually.
SEED_SUPER_ADMIN_EMAIL=


# ======================================================================
# AI  (optional)
# ======================================================================

# Powers AI writing assist, screening, and chat. If blank, AI features fall
# back to canned/demo responses instead of live generation.
ANTHROPIC_API_KEY=sk-ant-...


# ======================================================================
# EMAIL SENDING — SendGrid  (optional, but off = no email actually sends)
# ======================================================================
#
# If SENDGRID_API_KEY is blank, the app runs email in SANDBOX mode: every
# message (offers, approvals, hiring kickoffs, reminders) is written to the
# server log and NOT delivered. Flows still report success, so set this in
# any environment where real email must go out. Admin > Email Test shows
# whether email is live or sandboxed.
SENDGRID_API_KEY=

# From address / display name / reply-to on outgoing mail.
# Defaults: hr@lightspeedsystems.com / "Lightspeed Systems" / (none).
EMAIL_FROM=
EMAIL_FROM_NAME=
EMAIL_REPLY_TO=

# Shared secret that authenticates SendGrid Inbound Parse webhook posts to
# /api/webhooks/inbound-email. Blank = inbound email endpoint is unsecured/off.
INBOUND_EMAIL_SECRET=


# ======================================================================
# NOTIFICATION INBOXES  (optional — where routed emails/alerts go)
# ======================================================================
#
# Each falls back to a *.lightspeed.test placeholder if blank, which means
# those notifications go to a dead test address. Set these to real inboxes
# in production.
HR_EMAIL=
HR_INBOX=
HIRING_MANAGER_EMAIL=
HIRING_MANAGER_INBOX=
HIRING_TEAM_INBOX=
FINANCE_INBOX=
ELT_INBOX=


# ======================================================================
# INTERVIEW SCHEDULING  (optional)
# ======================================================================
#
# If a scheduling URL is blank, the matching scheduling action reports
# "not configured" rather than booking anything.

# Phone/first screen scheduling link.
PHONE_SCREEN_SCHEDULING_URL=

# Calendly scheduling link + webhook signing key (verifies Calendly callbacks).
CALENDLY_SCHEDULING_URL=
CALENDLY_WEBHOOK_SIGNING_KEY=

# Zoom webhook secret token (verifies Zoom scheduler callbacks). Blank = Zoom
# scheduling callbacks are not verified/handled.
ZOOM_WEBHOOK_SECRET_TOKEN=


# ======================================================================
# OFFER E-SIGNATURE — Adobe Sign  (optional)
# ======================================================================
#
# If ADOBE_SIGN_ACCESS_TOKEN is blank, offer e-signature runs as a STUB:
# it logs that it "would have sent" the document and sends nothing.
ADOBE_SIGN_ACCESS_TOKEN=
ADOBE_SIGN_BASE_URL=


# ======================================================================
# COGNITIVE / APTITUDE TEST — Criteria (CCAT)  (optional)
# ======================================================================
#
# If CRITERIA_API_KEY is blank, the CCAT integration runs in SANDBOX mode
# and returns simulated results — the CCAT Results screen shows illustrative
# sample data, not live scores. Set both to go live.
CRITERIA_API_KEY=
CRITERIA_PACKAGE_ID=


# ======================================================================
# VALUES ASSESSMENT API  (optional)
# ======================================================================
#
# Per-app key protecting the /api/values surface. Blank = that endpoint
# returns 503 "api-key-not-configured".
VALUES_API_KEY=


# ======================================================================
# AGENT FEEDBACK HARNESS  (optional)
# ======================================================================
#
# Per-app key for the cross-app debug-agent HTTP surface (/api/feedback).
# Blank = that surface is disabled.
AGENT_API_KEY=


# ======================================================================
# DOCUMENT LIBRARY — Dropbox  (optional)
# ======================================================================
#
# Powers the document index. All three credential values are required
# together; if any is blank, the Dropbox doc features are off.
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_REFRESH_TOKEN=
# Base folder path in Dropbox to index. Optional — has a sensible default.
DROPBOX_DOCS_PATH=


# ======================================================================
# EEO
# ======================================================================
#
# Set to "true" to auto-send the EEO self-ID invite. Anything else = off.
EEO_AUTO_INVITE=


# ======================================================================
# SEEDING / DEV DATA  (optional — dev + demo only)
# ======================================================================
#
# SEED_SYNTHETIC_RESUMES=true  seeds fake candidate resumes.
# SAMPLE_INTERVIEW_TRANSCRIPTS  seeds sample interview transcripts.
# RESEED  forces a reseed on boot. Leave all blank in production.
SEED_SYNTHETIC_RESUMES=
SAMPLE_INTERVIEW_TRANSCRIPTS=
RESEED=
